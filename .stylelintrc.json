{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "indentation": 2,
    "string-quotes": "double",
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "apply",
          "layer",
          "responsive",
          "screen"
        ]
      }
    ],
    "selector-class-pattern": null,
    "no-empty-source": null
  },
  "ignoreFiles": [
    "node_modules/**/*",
    "vendor/**/*"
  ]
}