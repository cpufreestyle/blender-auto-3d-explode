<?xml version="1.0"?>
<robot name="simple_robot">

  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </visual>
  </link>

  <!-- Tower Link -->
  <link name="tower_link">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 0.2"/>
      </geometry>
    </visual>
  </link>

  <joint name="base_to_tower" type="fixed">
    <parent link="base_link"/>
    <child link="tower_link"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
  </joint>

  <!-- Arm Link -->
  <link name="arm_link">
    <visual>
      <origin xyz="0.1 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.2"/>
      </geometry>
    </visual>
  </link>

  <joint name="tower_to_arm" type="revolute">
    <parent link="tower_link"/>
    <child link="arm_link"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <!-- Gripper Base -->
  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
    </visual>
  </link>

  <joint name="arm_to_gripper" type="fixed">
    <parent link="arm_link"/>
    <child link="gripper_base"/>
    <origin xyz="0.2 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Gripper Finger 1 -->
  <link name="finger_1">
    <visual>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
    </visual>
  </link>

  <joint name="gripper_to_finger_1" type="prismatic">
    <parent link="gripper_base"/>
    <child link="finger_1"/>
    <origin xyz="0.015 0 -0.02" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.02" effort="5" velocity="0.1"/>
  </joint>

  <!-- Gripper Finger 2 -->
  <link name="finger_2">
    <visual>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
    </visual>
  </link>

  <joint name="gripper_to_finger_2" type="prismatic">
    <parent link="gripper_base"/>
    <child link="finger_2"/>
    <origin xyz="-0.015 0 -0.02" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.02" effort="5" velocity="0.1"/>
  </joint>

  <!-- Sensor Head -->
  <link name="sensor_head">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </visual>
  </link>

  <joint name="gripper_to_sensor" type="fixed">
    <parent link="gripper_base"/>
    <child link="sensor_head"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
  </joint>

</robot>
